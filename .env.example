# 数据库配置
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your_password_here
DATABASE_NAME=shangtech_website

# MinIO 文件存储配置
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_access_key_here
MINIO_SECRET_KEY=your_secret_key_here
MINIO_USE_SSL=false
MINIO_BUCKET=shangtech-website

# JWT 配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# API 服务配置
API_PORT=4000
API_BASE_URL=http://localhost:4000

# Web 前端配置
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# CMS 前端配置
CMS_PORT=3001
NEXT_PUBLIC_CMS_API_URL=http://localhost:4000

# 邮件服务配置 (可选)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_email_password_here

# 管理员默认账号
ADMIN_EMAIL=admin@shangtech.com
ADMIN_PASSWORD=admin123